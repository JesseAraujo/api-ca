    "name": "API CA - je189758_GppApp CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleção CRUD para as tabelas: desertos, fiscalizacoes, indeferimentos, users e rate_limits."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "desertoId", "value": "deserto_demo_001" },
    { "key": "fiscalizacaoId", "value": "fiscal_demo_001" },
    { "key": "indeferimentoId", "value": "indef_demo_001" },
    { "key": "userId", "value": "user_demo_001" },
    { "key": "scope", "value": "login" },
    { "key": "ipHash", "value": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa" }
  ],
  "item": [
    {
      "name": "Desertos",
      "item": [
        {
          "name": "Listar desertos",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/desertos?limit=50&offset=0" }
        },
        {
          "name": "Buscar deserto por id",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/desertos/{{desertoId}}" }
        },
        {
          "name": "Criar deserto",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{desertoId}}\",\n  \"num_requerimento\": \"20260001965-HTQ\",\n  \"status\": \"Boletim Enviado\",\n  \"nome\": \"Fazenda Exemplo\",\n  \"municipio\": \"Itapeva\",\n  \"data_inicio_boletim\": \"2026-04-10\",\n  \"fiscal\": \"Fiscal Demo\"\n}"
            },
            "url": "{{baseUrl}}/api/desertos"
          }
        },
        {
          "name": "Atualizar deserto",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Boletim Concluído\",\n  \"acao_final\": \"Arquivado\",\n  \"data_conclusao\": \"2026-04-20\"\n}"
            },
            "url": "{{baseUrl}}/api/desertos/{{desertoId}}"
          }
        },
        {
          "name": "Excluir deserto",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/desertos/{{desertoId}}" }
        }
      ]
    },
